{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": true,
    "types": ["node", "@cloudflare/workers-types"]
  },
  "include": ["src/**/*.ts"]
}
